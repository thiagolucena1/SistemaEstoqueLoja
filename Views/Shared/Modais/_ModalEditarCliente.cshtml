@using EstoqueLojaV._0._2.Models.DTO
@model ClienteEditarDTO

<div class="modal fade" id="modalEditarCliente" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">✏️ Editar Cliente: @Model?.Nome</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" method="post">
                <div class="modal-body">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Nome" class="form-label">Nome do Cliente:</label>
                        <input asp-for="Nome" class="form-control" placeholder="@Model?.Nome" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">CPF/CNPJ</label>
                        <input asp-for="CpfOuCnpj"  class="form-control" value="@Model?.CpfOuCnpj" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class =" form-control" value="@Model?.Email" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telefone</label>
                        <input asp-for="Telefone" class="form-control" value="@Model?.Telefone" readonly />
                    </div>
                   
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/Cliente/validacoesCliente.js"></script>
