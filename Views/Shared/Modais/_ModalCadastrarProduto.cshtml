<div class="modal fade"
     id="modalCadastrarProduto"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Cadastro de Produto
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <form asp-action="CriarProdutosModal" method="post">

                    <div class="mb-3">
                        <label for="Nome">Nome</label>
                        <input type="text"
                               id="Nome"
                               name="Nome"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="Descricao">Descrição</label>
                        <textarea id="Descricao"
                                  name="Descricao"
                                  class="form-control"
                                  rows="4">
                     </textarea>
                    </div>

                    <div class="mb-3">
                        <label for="Preco">Preço</label>
                        <input type="number"
                               id="Preco"
                               name="Preco"
                               step="0.01"
                               min="0"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="Quantidade">Quantidade</label>
                        <input type="number"
                               id="Quantidade"
                               name="Quantidade"
                               min="0"
                               class="form-control" />
                    </div>

                    <button type="submit"
                            class="btn btn-success">
                        Salvar
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>