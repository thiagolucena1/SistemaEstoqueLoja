@model IEnumerable<EstoqueLojaV._0._2.Models.ClientesEntites.Cliente>
@await Html.PartialAsync("~/Views/Shared/Modais/_ModalCadastrarCliente.cshtml")


@{
    ViewData["Title"] = "Clientes";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">👤 Controle de Clientes</h2>
            <p class="text-muted m-0">Gerencie os clientes cadastrados na sua loja.</p>
        </div>
    </div>

    <div>
        <button class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#modalCadastrarCliente">
            Cadastrar Cliente
        </button>

        <button class="btn btn-primary"
                onclick="document.getElementById('inputArquivo').click()">
            📂 Importar Clientes
        </button>

        @await Html.PartialAsync("~/Views/Shared/_FormImportar.cshtml", "ImportarClientes")
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom text-secondary fw-semibold">
                    <tr>
                        <th class="ps-4 py-3">Código</th>
                        <th class="py-3">Nome</th>
                        <th class="py-3">CPF/CNPJ</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">Telefone</th>
                        <th class="py-3">Data Cadastro</th>
                        <th class="py-3 text-center">Status</th>
                        <th class="pe-4 py-3 text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model is null)
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                Nenhum cliente cadastrado no momento.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-secondary fw-medium">#@item.Id</td>
                                <td class="fw-semibold text-dark">@item.Nome</td>
                                <td class="text-muted">@item.CpfCnpj</td>
                                <td class="text-muted">@item.Email</td>
                                <td class="text-muted">@item.Telefone</td>
                                <td class="text-muted">@item.DataCadastro.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <span class="badge @(item.Ativo ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-3 py-2 rounded-pill">
                                        @(item.Ativo ? "Ativo" : "Inativo")
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-1">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">Excluir</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Cliente/validacoesCliente.js"></script>
}